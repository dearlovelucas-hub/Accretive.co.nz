# Copy this file to `.env.test-branch` when running tests against a remote
# Vercel/Neon test branch database.
#
# WARNING:
# The test harness truncates core tables between test cases. Use a dedicated
# database branch for automated tests.

DATABASE_URL_TEST=postgres://USER:PASSWORD@HOST:5432/DB_NAME?sslmode=require

# Optional but recommended when sharing a test database branch:
# ACCRETIVE_DB_SCHEMA=accretive_test_branch

# Optional override. The npm scripts already set a test-only default.
# SESSION_SECRET=test-only-session-secret-1234
